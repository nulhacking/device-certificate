# Railway production — https://device-certificate-production.up.railway.app

NODE_ENV=production
JWT_SECRET=change-me-to-long-random-string
DB_PATH=/data/app.db

# WebAuthn (kod avtomatik ham aniqlaydi, lekin aniq qo'yish tavsiya etiladi)
RP_ID=device-certificate-production.up.railway.app
ORIGIN=https://device-certificate-production.up.railway.app
CORS_ORIGIN=https://device-certificate-production.up.railway.app
RP_NAME=Device Certificate Login

# Admin (production da o'zgartiring!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
DEMO_USERNAME=user1
DEMO_PASSWORD=change-me-strong-password
